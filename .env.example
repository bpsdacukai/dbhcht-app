# Salin file ini menjadi .env dan isi dengan kredensial Supabase Anda
# Copy this file to .env and fill in your Supabase credentials

VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL API Anthropic (untuk fitur AI) — diakses via proxy Supabase Edge Function
# Jangan masukkan API key Anthropic di sini karena akan terekspos ke browser
# Gunakan Supabase Edge Function sebagai proxy (lihat supabase/functions/)
VITE_AI_PROXY_URL=/api/ai
